DATABASE_URL=sqlite:///./protoryde.db
# Render PostgreSQL (uncomment and replace with your actual URL):
# DATABASE_URL=postgresql://user:password@host.singapore-postgres.render.com/dbname
ENABLE_SCHEDULER=false
ENABLE_ML_RETRAIN=false
ML_RETRAIN_INTERVAL_HOURS=24

# Open-data bank branch source (Overpass / OpenStreetMap)
BANK_BRANCH_OVERPASS_URL=https://overpass-api.de/api/interpreter
BANK_SEARCH_RADIUS_METERS=5000
BANK_BRANCH_TIMEOUT_SECONDS=12
BANK_DATA_CACHE_TTL_SECONDS=21600
